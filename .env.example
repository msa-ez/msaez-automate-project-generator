# OpenAI 표준 환경변수 (SDK가 그대로 읽음)
# - OPENAI_BASE_URL이 비어있으면 OpenAI 공용 API 사용
# - OPENAI_BASE_URL에 게이트웨이(P-GPT 등)를 넣으면 Chat/Responses/Models가 그쪽으로 라우팅
#   이 경우 OPENAI_API_KEY는 게이트웨이에서 발급받은 키를 넣는다.
#   임베딩은 게이트웨이 미지원이라 OpenAI 공용으로 자동 격리되므로,
#   OPENAI_EMBEDDING_API_KEY에 진짜 OpenAI 키를 반드시 함께 넣어야 한다.
# 개발계: http://taigpt.posco.net/gpgpta01-gpt/v1
# 운영계: http://aigpt.posco.net/gpgpta01-gpt/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_API_KEY=
# OPENAI_EMBEDDING_BASE_URL=   # 필요 시 별도 임베딩 엔드포인트 지정

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-credentials.json
FIREBASE_DATABASE_URL=https://eventstorming-tool-db.firebaseio.com
FIREBASE_STORAGE_BUCKET=gs://eventstorming-tool-db.appspot.com
# 모든 create_chat_llm() 호출이 이 모델을 기본으로 사용한다.
# P-GPT 게이트웨이 사용 시에는 /v1/models에 등록된 모델 ID로 맞춰야 한다 (예: gpt-4o).
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.7
ENVIRONMENT=development
DEBUG=true
NAMESPACE=eventstorming_generator
POD_ID=local-dev
IS_LOCAL_RUN=true

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Job monitor 메타 업데이트 간격(초)
# AceBase 과부하 완화를 위해 폴링보다 느리게 운영 권장
JOB_HEARTBEAT_INTERVAL=4.0
JOB_WAITING_COUNT_UPDATE_INTERVAL=6.0
JOB_RECOVERY_CHECK_INTERVAL=10.0

# acebase 사용시 추가, Storage 사용 타입
STORAGE_TYPE=acebase

# Firebase 관련 설정 제거하고 대신 추가
ACEBASE_HOST=127.0.0.1
ACEBASE_PORT=5757
ACEBASE_DB_NAME=mydb
ACEBASE_HTTPS=false
ACEBASE_USERNAME=admin
ACEBASE_PASSWORD=75sdDSFg37w5